{
  "manifest_version": 3,
  "name": "Claude Cloak",
  "version": "0.1.0",
  "description": "Hide Project chats from your Claude sidebar with a single toggle. Private, lightweight, no data collected.",
  "homepage_url": "https://github.com/your-org/claude-cloak",
  "key": "",
  "author": "Claude Cloak contributors",
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "action": {
    "default_title": "Claude Cloak",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ]
}
